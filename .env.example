# ============================================================
# Variáveis de ambiente para a demo do Red Hat Developer Hub
# Copie este arquivo para .env e preencha com seus valores
# NUNCA faça commit do arquivo .env
# ============================================================

# --- OpenShift ---
# Namespace onde o RHDH está instalado
OCP_NAMESPACE=tssc-dh

# --- Azure DevOps ---
# Nome da organização em dev.azure.com/<ORG>
AZURE_DEVOPS_ORG=<SUA_ORG_ADO>
# Nome do projeto dentro da organização
AZURE_DEVOPS_PROJECT=<SEU_PROJETO_ADO>
# Personal Access Token com escopos: Build (R/W), Code (R), Service Connections (R)
AZURE_DEVOPS_PAT=<SEU_PAT_ADO>

# --- GitHub ---
# Usuário ou organização GitHub onde os repositórios serão criados
GITHUB_USER=<SEU_USUARIO_GITHUB>

# --- RHDH — nomes dos recursos no cluster (descobertos via oc get) ---
# ConfigMap de app-config gerenciado pelo operador
RHDH_CONFIGMAP_APPCONFIG=tssc-developer-hub-app-config
# ConfigMap de dynamic-plugins gerenciado pelo operador
RHDH_CONFIGMAP_PLUGINS=tssc-developer-hub-dynamic-plugins
# Secret de variáveis de ambiente da aplicação
RHDH_SECRET=tssc-developer-hub-env
# Nome do Deployment do Backstage
RHDH_DEPLOYMENT=backstage-developer-hub

# --- Gerado pelo script 04 ---
# Execute: bash scripts/04-get-connected-service-id.sh
# e cole o ID da Service Connection GitHub do seu projeto ADO
AZURE_GITHUB_SERVICE_CONNECTION_ID=<ID_DA_SERVICE_CONNECTION_GITHUB>
